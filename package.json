{
  "name": "gasino-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs --format=cjs --external:vite",
    "preview": "vite preview",
    "lint": "tsc",
    "cap:sync": "npx cap sync",
    "cap:add-android": "npx cap add android",
    "cap:open-android": "npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "icons:generate": "npx capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.562.0",
    "motion": "^12.38.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
